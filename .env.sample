# Copy this file to .env. Bun loads .env automatically.

# Required when running with --api.
MEDIA_TAG_API_KEY=sk-your-api-key-here

# Optional. Any OpenAI-compatible endpoint. CLI flags --api-base-url / --api-model take precedence.
MEDIA_TAG_BASE_URL=https://api.openai.com/v1
MEDIA_TAG_MODEL=gpt-4o-mini
