# Copy this file to .env. Bun loads .env automatically.

# Required when running with --api.
MEDIA_TAG_API_KEY=sk-your-api-key-here

# Default endpoint + model for image/video tagging.
# Any OpenAI-compatible endpoint. CLI flags --api-base-url / --api-model take precedence.
MEDIA_TAG_BASE_URL=https://api.openai.com/v1
MEDIA_TAG_MODEL=gpt-4o-mini

# Optional audio overrides. Audio tagging needs an audio-capable model;
# point these at a different endpoint/model/key when your default model cannot hear audio.
# Each falls back to MEDIA_TAG_BASE_URL / MEDIA_TAG_MODEL / MEDIA_TAG_API_KEY when unset.
MEDIA_TAG_AUDIO_BASE_URL=
MEDIA_TAG_AUDIO_MODEL=gemini/gemini-3-flash-preview
MEDIA_TAG_AUDIO_API_KEY=
